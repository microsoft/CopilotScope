---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getOrderedLenses, LENS_ICON } from '../lib/lenses';
import Icon from '../components/Icon.astro';

interface Props {
  title?: string;
}
const { title = 'CopilotScope' } = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.replace(/\/+$/, ''); // '/CopilotScope'
const home = base + '/';
const faviconHref = `${base}/favicon-mark.png`;
const markHref = `${base}/logo-mark.png`;
const markDarkHref = `${base}/logo-mark-dark.png`;
const repoUrl = 'https://github.com/microsoft/CopilotScope';

const strip = (p: string): string => p.replace(/\/+$/, '') || '/';
const current = strip(Astro.url.pathname);

type NavLink = {
  label: string;
  href: string;
  icon: string;
  tint?: string;
  indent?: boolean;
  external?: boolean;
  rel?: string;
  ariaLabel?: string;
};
type NavDivider = { divider: true; push?: boolean };
type NavGroup = { group: string; icon: string; children: NavLink[] };
type NavEntry = NavLink | NavDivider | NavGroup;

const isDivider = (e: NavEntry): e is NavDivider => 'divider' in e;
const isGroup = (e: NavEntry): e is NavGroup => 'group' in e;

const lensNav: NavLink[] = [
  { label: 'Overview', href: `${base}/lenses`, icon: 'grid', indent: true },
  ...(await getOrderedLenses()).map((d) => ({
    label: d.name,
    href: `${base}/lenses/${d.id}`,
    icon: LENS_ICON[d.id],
    tint: d.color,
    indent: true,
  })),
];

const nav: NavEntry[] = [
  { label: 'Home', href: home, icon: 'home' },
  { label: 'Getting Started', href: base + '/getting-started', icon: 'rocket' },
  { label: 'Data Sources', href: base + '/data-sources', icon: 'database' },
  { divider: true },
  { label: 'Lens Finder', href: base + '/lens-finder', icon: 'target' },
  { group: 'Lenses', icon: 'aperture', children: lensNav },
  { divider: true, push: true },
  { label: "What's New", href: base + '/whats-new', icon: 'sparkle' },
  { label: 'FAQ & Support', href: base + '/about', icon: 'info' },
  { label: 'Copilot Analytics Lab', href: 'https://microsoft.github.io/CopilotAnalyticsLabs', icon: 'scatter', external: true, rel: 'noopener noreferrer', ariaLabel: 'Copilot Analytics Lab (opens in new tab)' },
  { label: 'GitHub', href: repoUrl, icon: 'github', external: true },
];

const isActive = (item: NavLink): boolean => !item.external && strip(item.href) === current;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('csTheme');
          if (t !== 'light' && t !== 'dark') t = 'light';
          document.documentElement.dataset.theme = t;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <header class="topbar">
      <div class="topbar-left">
        <button
          id="hamburger"
          class="hamburger"
          type="button"
          aria-label="Toggle navigation"
          aria-controls="rail"
          aria-expanded="false"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
        <a class="brand" href={home} aria-label="CopilotScope home">
          <img class="brand-mark brand-mark-light" src={markHref} alt="" height="31" />
          <img class="brand-mark brand-mark-dark" src={markDarkHref} alt="" height="31" />
          <span class="brand-name">CopilotScope</span>
        </a>
        <a class="topbar-stamp" href={base + '/whats-new'} aria-label="Work in progress - see What's New">
          <img src={`${base}/work-in-progress-stamp.png`} alt="Work in progress" />
        </a>
      </div>
      <div class="topbar-right">
        <button
          id="theme-toggle"
          class="theme-toggle"
          type="button"
          role="switch"
          aria-checked="false"
          aria-label="Toggle dark mode"
        >
          <span class="tt-glyph tt-sun" aria-hidden="true"><Icon name="sun" size={14} /></span>
          <span class="tt-glyph tt-moon" aria-hidden="true"><Icon name="moon" size={14} /></span>
          <span class="tt-thumb" aria-hidden="true"></span>
        </button>
      </div>
    </header>

    <div class="shell">
      <nav id="rail" class="rail" aria-label="Primary" transition:persist>
        <ul>
          {
            nav.map((item) =>
              isDivider(item) ? (
                <li class:list={['rail-divider', { push: item.push }]} aria-hidden="true" />
              ) : isGroup(item) ? (
                <li class="rail-group open">
                  <button
                    type="button"
                    class="rail-link rail-toggle"
                    aria-expanded="true"
                    aria-controls={`railsub-${item.group}`}
                  >
                    <span class="rail-icon">
                      <Icon name={item.icon} />
                    </span>
                    <span class="rail-label">{item.group}</span>
                    <span class="rail-chevron" aria-hidden="true">
                      <Icon name="chevron" size={16} />
                    </span>
                  </button>
                  <ul class="rail-sub" id={`railsub-${item.group}`}>
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class:list={['rail-link', 'indent', { active: isActive(child) }]}
                          data-path={strip(child.href)}
                          aria-current={isActive(child) ? 'page' : undefined}
                          style={child.tint ? `--row-tint: var(--${child.tint});` : undefined}
                        >
                          <span class="rail-icon">
                            <Icon name={child.icon} />
                          </span>
                          <span class="rail-label">{child.label}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li>
                  <a
                    href={item.href}
                    class:list={['rail-link', { active: isActive(item), indent: item.indent }]}
                    data-path={item.external ? undefined : strip(item.href)}
                    target={item.external ? '_blank' : undefined}
                    rel={item.external ? (item.rel ?? 'noopener') : undefined}
                    aria-label={item.ariaLabel}
                    aria-current={isActive(item) ? 'page' : undefined}
                    style={item.tint ? `--row-tint: var(--${item.tint});` : undefined}
                  >
                    <span class="rail-icon">
                      <Icon name={item.icon} />
                    </span>
                    <span class="rail-label">{item.label}</span>
                    {item.external && <span class="ext" aria-hidden="true">↗</span>}
                  </a>
                </li>
              )
            )
          }
          <li class="rail-divider" aria-hidden="true"></li>
          <li class="rail-badge-li">
            <a
              class="rail-badge"
              href="https://opensource.microsoft.com/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Microsoft Open Source (opens in new tab)"
            >
              <img class="ms-oss ms-oss-light" src={`${base}/ms-opensource-light.png`} alt="Microsoft Open Source" />
              <img class="ms-oss ms-oss-dark" src={`${base}/ms-opensource-dark.png`} alt="Microsoft Open Source" />
            </a>
          </li>
        </ul>
      </nav>

      <div class="backdrop" id="nav-backdrop" aria-hidden="true"></div>

      <main id="main" class="content" tabindex="-1">
        <slot />
      </main>
    </div>

    <script>
      const KEY = 'csTheme';

      function currentTheme(): 'light' | 'dark' {
        return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      }
      function applyTheme(t: 'light' | 'dark'): void {
        document.documentElement.dataset.theme = t;
      }
      function syncToggle(): void {
        const btn = document.getElementById('theme-toggle');
        if (btn) btn.setAttribute('aria-checked', String(currentTheme() === 'dark'));
      }
      function toggleTheme(): void {
        const next = currentTheme() === 'dark' ? 'light' : 'dark';
        applyTheme(next);
        try {
          localStorage.setItem(KEY, next);
        } catch (e) {
          /* storage unavailable — theme still applies for this session */
        }
        syncToggle();
      }
      function setupToggle(): void {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        syncToggle();
        btn.addEventListener('click', toggleTheme);
        btn.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ' || e.key === 'Spacebar') {
            e.preventDefault();
            toggleTheme();
          }
        });
      }
      function setupNav(): void {
        const burger = document.getElementById('hamburger');
        const backdrop = document.getElementById('nav-backdrop');
        if (burger) {
          burger.addEventListener('click', () => {
            const open = document.body.classList.toggle('nav-open');
            burger.setAttribute('aria-expanded', String(open));
          });
        }
        if (backdrop) {
          backdrop.addEventListener('click', () => {
            document.body.classList.remove('nav-open');
            if (burger) burger.setAttribute('aria-expanded', 'false');
          });
        }
      }
      function updateActive(): void {
        const cur = location.pathname.replace(/\/+$/, '') || '/';
        document.querySelectorAll<HTMLAnchorElement>('.rail-link[data-path]').forEach((a) => {
          const active = a.getAttribute('data-path') === cur;
          a.classList.toggle('active', active);
          if (active) a.setAttribute('aria-current', 'page');
          else a.removeAttribute('aria-current');
        });
      }
      function setupLensGroup(): void {
        const group = document.querySelector<HTMLElement>('.rail-group');
        if (!group) return;
        const btn = group.querySelector<HTMLButtonElement>('.rail-toggle');
        if (!btn) return;
        btn.setAttribute('aria-expanded', String(group.classList.contains('open')));
        if (!btn.dataset.bound) {
          btn.addEventListener('click', () => {
            const open = group.classList.toggle('open');
            btn.setAttribute('aria-expanded', String(open));
          });
          btn.dataset.bound = '1';
        }
      }

      // astro:page-load fires on the initial load and after every client-side
      // navigation, so it re-binds the (re-rendered) top bar controls and
      // re-computes the active rail item for the persisted rail.
      document.addEventListener('astro:page-load', () => {
        setupToggle();
        setupNav();
        updateActive();
        setupLensGroup();
      });

      // The <html> element persists across a view-transition swap; re-assert
      // the stored theme so it never regresses to the default.
      document.addEventListener('astro:after-swap', () => {
        const t = localStorage.getItem(KEY);
        document.documentElement.dataset.theme = t === 'dark' ? 'dark' : 'light';
      });
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        padding: var(--sp-2) var(--sp-4);
        background: var(--surface-card);
        color: var(--ink);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-2);
      }
      .skip-link:focus {
        left: var(--sp-3);
        top: var(--sp-3);
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 40;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--sp-4);
        height: 56px;
        padding: 0 var(--sp-4);
        background: var(--surface-card);
        border-bottom: 1px solid var(--border);
      }
      html[data-theme='light'] .topbar {
        background: var(--surface-page);
      }
      .topbar-left,
      .topbar-right {
        display: flex;
        align-items: center;
        gap: var(--sp-3);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 13px;
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand-mark {
        height: 31px;
        width: auto;
        display: block;
      }
      .brand-mark-dark {
        display: none;
      }
      html[data-theme='dark'] .brand-mark-light {
        display: none;
      }
      html[data-theme='dark'] .brand-mark-dark {
        display: block;
      }
      .brand-name {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--ink);
        white-space: nowrap;
      }
      .topbar-stamp {
        display: inline-flex;
        align-items: center;
        transform: rotate(-20deg);
        transition: transform var(--dur) var(--ease);
      }
      .topbar-stamp img {
        display: block;
        height: 32px;
        width: auto;
        pointer-events: none;
      }
      .topbar-stamp:hover {
        transform: rotate(-16deg) scale(1.06);
      }
      .topbar-stamp:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 6px;
      }

      .hamburger {
        display: none;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        padding: 0;
        color: var(--ink);
        background: var(--surface-raised);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        cursor: pointer;
      }
      .hamburger svg {
        width: 18px;
        height: 18px;
      }
      .hamburger:hover {
        background: var(--accent-subtle);
      }

      .theme-toggle {
        position: relative;
        display: inline-flex;
        align-items: center;
        width: 56px;
        height: 28px;
        padding: 0;
        background: var(--surface-raised);
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        cursor: pointer;
      }
      .theme-toggle .tt-glyph {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        display: inline-flex;
        z-index: 2;
        color: var(--subtle);
        pointer-events: none;
      }
      .theme-toggle .tt-sun {
        left: 6px;
      }
      .theme-toggle .tt-moon {
        right: 6px;
      }
      .theme-toggle .tt-thumb {
        position: absolute;
        top: 2px;
        left: 2px;
        z-index: 1;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--surface-card);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-1);
        transition: transform var(--dur) var(--ease);
      }
      html[data-theme='dark'] .theme-toggle .tt-thumb {
        transform: translateX(28px);
      }
      html[data-theme='light'] .theme-toggle .tt-sun {
        color: var(--accent);
      }
      html[data-theme='dark'] .theme-toggle .tt-moon {
        color: var(--accent);
      }

      .shell {
        display: grid;
        grid-template-columns: 248px minmax(0, 1fr);
        align-items: start;
      }

      .rail {
        position: sticky;
        top: 56px;
        height: calc(100vh - 56px);
        overflow-y: auto;
        padding: var(--sp-3) var(--sp-2);
        background: var(--surface-card);
        border-right: 1px solid var(--border);
      }
      html[data-theme='light'] .rail {
        background: var(--surface-page);
      }
      .rail ul {
        list-style: none;
        margin: 0;
        padding: 0;
        min-height: 100%;
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .rail-divider {
        height: 1px;
        margin: var(--sp-2) var(--sp-2);
        background: var(--border);
      }
      .rail-divider.push {
        margin-top: auto;
      }
      .rail-link {
        position: relative;
        display: flex;
        align-items: center;
        gap: var(--sp-3);
        height: 36px;
        padding: 0 var(--sp-3) 0 14px;
        color: var(--ink);
        font-size: 15px;
        font-weight: 500;
        border-radius: var(--radius-sm);
        transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
      }
      .rail-link.indent {
        padding-left: 26px;
      }
      .rail-link:hover {
        background: color-mix(in srgb, var(--ink) 5%, transparent);
        text-decoration: none;
      }
      .rail-link.active {
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        color: var(--accent);
        font-weight: 600;
      }
      .rail-link.active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 4px;
        bottom: 4px;
        width: 3px;
        border-radius: 0 3px 3px 0;
        background: var(--accent);
      }
      .rail-icon {
        display: inline-flex;
        flex: 0 0 auto;
        color: var(--row-tint, var(--muted));
      }
      .rail-link.active .rail-icon {
        color: var(--accent);
      }
      .rail-label {
        min-width: 0;
      }
      .rail-link .ext {
        margin-left: auto;
        font-size: 12px;
        color: var(--subtle);
      }

      .rail-group {
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .rail-toggle {
        width: 100%;
        background: none;
        border: 0;
        cursor: pointer;
        font-family: inherit;
        color: inherit;
      }
      .rail-chevron {
        margin-left: auto;
        display: inline-flex;
        color: var(--subtle);
        transition: transform var(--dur) var(--ease);
      }
      .rail-group.open .rail-chevron {
        transform: rotate(90deg);
      }
      .rail-sub {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1px;
        overflow: hidden;
        max-height: 0;
        transition: max-height var(--dur) var(--ease);
      }
      .rail-group.open .rail-sub {
        max-height: 420px;
      }

      .rail-badge-li {
        display: block;
      }
      .rail-badge {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px 12px 0px;
        border-radius: var(--radius-sm);
      }
      .rail-badge:hover {
        background: color-mix(in srgb, var(--ink) 5%, transparent);
        text-decoration: none;
      }
      .rail-badge:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .ms-oss {
        display: block;
        width: 93px;
        height: auto;
        opacity: 0.9;
      }
      .rail-badge:hover .ms-oss {
        opacity: 1;
      }
      .ms-oss-dark {
        display: none;
      }
      html[data-theme='dark'] .ms-oss-light {
        display: none;
      }
      html[data-theme='dark'] .ms-oss-dark {
        display: block;
      }
      .content {
        min-width: 0;
        max-width: 1100px;
        padding: 40px 40px 64px;
      }

      .backdrop {
        display: none;
      }

      @media (max-width: 860px) {
        .shell {
          grid-template-columns: minmax(0, 1fr);
        }
        .hamburger {
          display: inline-flex;
        }
        .rail {
          position: fixed;
          top: 56px;
          left: 0;
          z-index: 45;
          width: 264px;
          max-width: 82vw;
          height: calc(100vh - 56px);
          transform: translateX(-100%);
          transition: transform var(--dur) var(--ease);
          box-shadow: var(--shadow-2);
        }
        body.nav-open .rail {
          transform: translateX(0);
        }
        .backdrop {
          display: none;
          position: fixed;
          inset: 56px 0 0 0;
          z-index: 44;
          background: rgba(0, 0, 0, 0.42);
        }
        body.nav-open .backdrop {
          display: block;
        }
        .content {
          padding: var(--sp-5) var(--sp-4) var(--sp-7);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .rail,
        .theme-toggle .tt-thumb,
        .rail-link {
          transition: none;
        }
      }
    </style>
  </body>
</html>
