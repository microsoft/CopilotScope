---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const lenses = await getCollection('lenses');

// Explicit display order + per-lens glyph (the JSON `icon` field is null).
const ORDER = [
  'valuelens',
  'adoptionlens',
  'readinesslens',
  'maturitylens',
  'leaderlens',
  'studiolens',
  'behaviorlens',
  'governancelens',
];

const ICON_BY_ID = {
  valuelens: 'trending-up',
  adoptionlens: 'people',
  readinesslens: 'clipboard-check',
  maturitylens: 'bar-chart',
  leaderlens: 'trophy',
  studiolens: 'bot',
  behaviorlens: 'brain',
  governancelens: 'shield',
};

const STATUS_RANK = { installed: 0, available: 1, 'coming-soon': 2 };

const STATUS_LABEL = {
  installed: 'Installed',
  available: 'Available',
  'coming-soon': 'Coming Soon',
};

const byId = new Map(lenses.map((entry) => [entry.data.id, entry.data]));

const orderedLenses = ORDER.map((id) => {
  const data = byId.get(id);
  return {
    id,
    name: data.name,
    tagline: data.tagline,
    color: data.color,
    status: data.status,
    icon: ICON_BY_ID[id],
    href: `${base}/lenses/${id}`,
  };
}).sort((a, b) => STATUS_RANK[a.status] - STATUS_RANK[b.status]);
---

<BaseLayout title="CopilotScope — One scope, many lenses.">
  <div class="home">
    <!-- ============================ Hero ============================ -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-text">
        <h1 id="hero-title">One scope, many lenses.</h1>
        <p class="hero-sub">The Frontier Copilot Reporting Kit &#8212; Power BI lenses to measure the value, adoption, maturity, behaviour and impact of Microsoft 365 Copilot.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={base + '/getting-started'}>Get started</a>
        </div>
      </div>

      <div class="hero-art-wrap">
        <img class="hero-mark hero-mark-light" src={`${base}/logo-mark.png`} alt="CopilotScope logo &#8212; lens ring with magnifier handle" />
        <img class="hero-mark hero-mark-dark" src={`${base}/logo-mark-dark.png`} alt="CopilotScope logo &#8212; lens ring with magnifier handle" />
        <svg
          class="hero-art"
          viewBox="0 56 480 258"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <linearGradient id="csSparkGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="var(--accent)" stop-opacity="0.28" />
              <stop offset="1" stop-color="var(--accent)" stop-opacity="0" />
            </linearGradient>
          </defs>

          <!-- Halo + orbit rings (the real logo mark is the centerpiece, layered over these) -->
          <g class="ring" aria-hidden="true">
            <circle class="halo" cx="248" cy="186" r="128" fill="var(--accent)" opacity="0.06" />
            <circle class="orbit" cx="248" cy="186" r="164" />
            <circle class="orbit" cx="248" cy="186" r="190" />
          </g>

          <!-- Satellite chip: mini sparkline -->
          <g class="chip" aria-hidden="true">
            <rect class="chip-card" x="39" y="78" width="112" height="60" rx="14" />
            <polygon class="spark-area" points="55,122 73,110 89,116 107,98 125,104 137,92 137,130 55,130" fill="url(#csSparkGrad)" />
            <polyline class="spark-line" points="55,122 73,110 89,116 107,98 125,104 137,92" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </g>

          <!-- Satellite chip: mini donut -->
          <g class="chip" aria-hidden="true">
            <rect class="chip-card" x="59" y="211" width="84" height="84" rx="16" />
            <circle cx="101" cy="253" r="24" fill="none" stroke="var(--border)" stroke-width="9" />
            <circle cx="101" cy="253" r="24" fill="none" stroke="var(--lens-blue)" stroke-width="9" stroke-linecap="round" stroke-dasharray="98 152" transform="rotate(-90 101 253)" />
          </g>

          <!-- Satellite chip: checklist -->
          <g class="chip" aria-hidden="true">
            <rect class="chip-card" x="356" y="86" width="104" height="96" rx="16" />
            <path class="check" d="M372 112 l6 6 l11 -13" fill="none" stroke="var(--lens-green)" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <rect x="398" y="108" width="48" height="6" rx="3" fill="var(--border-strong)" />
            <path class="check" d="M372 138 l6 6 l11 -13" fill="none" stroke="var(--lens-green)" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <rect x="398" y="134" width="48" height="6" rx="3" fill="var(--border-strong)" />
            <path class="check" d="M372 164 l6 6 l11 -13" fill="none" stroke="var(--lens-green)" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <rect x="398" y="160" width="40" height="6" rx="3" fill="var(--border-strong)" />
          </g>
        </svg>
      </div>
    </section>

    <!-- ======================= Category cards ======================= -->
    <section class="cat-cards" aria-label="Explore lenses by category">
      <a class="cat-card" href={base + '/lenses'}>
        <span class="cat-icon cat-green"><Icon name="trending-up" size={28} /></span>
        <span class="cat-body">
          <span class="cat-title">Value &amp; ROI</span>
          <span class="cat-text">Measure financial impact and productivity gains.</span>
        </span>
      </a>
      <a class="cat-card" href={base + '/lenses'}>
        <span class="cat-icon cat-blue"><Icon name="bot" size={28} /></span>
        <span class="cat-body">
          <span class="cat-title">Agents &amp; Studio</span>
          <span class="cat-text">Evaluate and optimize agent performance.</span>
        </span>
      </a>
      <a class="cat-card" href={base + '/lenses'}>
        <span class="cat-icon cat-purple"><Icon name="people" size={28} /></span>
        <span class="cat-body">
          <span class="cat-title">Adoption &amp; Readiness</span>
          <span class="cat-text">Drive adoption and build organizational readiness.</span>
        </span>
      </a>
    </section>

    <!-- ========================= Lens grid ========================= -->
    <section class="lens-section" aria-labelledby="lens-h2">
      <h2 id="lens-h2">Swap the lens. Change the question.</h2>
      <div class="lens-grid">
        {orderedLenses.map((lens) => (
          <a class="lens-tile" href={lens.href}>
            <span
              class="tile-icon"
              style={`--tile-c: var(--${lens.color}); background: var(--tile-c)`}
              transition:name={`lens-icon-${lens.id}`}
            >
              <Icon name={lens.icon} size={24} />
            </span>
            <span class="tile-text">
              <span class:list={['pill', `pill--${lens.status}`]}>{STATUS_LABEL[lens.status]}</span>
              <span class="tile-name">{lens.name}</span>
              <span class="tile-tag">{lens.tagline}</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <style>
    .home {
      display: flex;
      flex-direction: column;
      gap: 28px;
      margin-top: calc(var(--sp-2) * -1);
    }

    /* ---------- Hero ---------- */
    .hero {
      display: grid;
      grid-template-columns: 1.25fr 0.75fr;
      gap: var(--sp-5);
      align-items: center;
    }
    .hero-text {
      animation: heroFade 520ms var(--ease) both;
    }
    .hero-text h1 {
      font-size: clamp(2.2rem, 4.4vw, 2.7rem);
      font-weight: 750;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin: 0 0 var(--sp-3);
    }
    .hero-sub {
      font-size: clamp(1.02rem, 1.4vw, 1.12rem);
      line-height: 1.5;
      color: var(--muted);
      max-width: none;
      margin: 0 0 var(--sp-4);
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-3);
    }

    /* ---------- Buttons ---------- */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 22px;
      font-size: 0.98rem;
      font-weight: 650;
      border-radius: var(--radius-sm);
      border: 1px solid transparent;
      cursor: pointer;
      transition: background-color var(--dur) var(--ease),
        border-color var(--dur) var(--ease), color var(--dur) var(--ease),
        transform var(--dur-fast) var(--ease);
    }
    .btn:hover { text-decoration: none; }
    .btn:active { transform: translateY(1px); }
    .btn-primary {
      background: var(--accent);
      color: #fff;
    }
    .btn-primary:hover {
      background: var(--accent-hover);
      color: #fff;
    }

    /* ---------- Hero art ---------- */
    .hero-art-wrap {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-mark {
      position: absolute;
      top: 50%;
      left: 50%;
      /* Ring-center (not bbox-center) aligned onto the orbit-ring center, and
         sized to 180px so the whole mark stays inside .hero-art-wrap. */
      transform: translate(-67.5px, -72.9px);
      width: 180px;
      max-width: 325px;
      height: auto;
      z-index: 2;
      pointer-events: none;
      animation: heroMarkFade 560ms var(--ease) both;
    }
    .hero-mark-dark {
      display: none;
    }
    html[data-theme='dark'] .hero-mark-light {
      display: none;
    }
    html[data-theme='dark'] .hero-mark-dark {
      display: block;
    }
    .hero-art {
      width: 100%;
      max-width: 380px;
      height: auto;
      display: block;
      overflow: visible;
      pointer-events: none;
      animation: heroRise 560ms var(--ease) both;
    }
    .hero-art .orbit {
      fill: none;
      stroke: var(--border-strong);
      stroke-width: 1.4;
      opacity: 0.35;
    }
    .hero-art .chip {
      filter: drop-shadow(0 6px 14px rgba(16, 24, 40, 0.16));
    }
    .hero-art .chip-card {
      fill: var(--surface-card);
      stroke: var(--border);
      stroke-width: 1.5;
    }

    @keyframes heroRise {
      from { opacity: 0; transform: translateY(18px); }
      to { opacity: 1; transform: none; }
    }
    @keyframes heroMarkFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes heroFade {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: none; }
    }

    /* ---------- Category cards ---------- */
    .cat-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--sp-4);
      margin-top: -14px;
    }
    .cat-card {
      display: flex;
      align-items: center;
      gap: var(--sp-4);
      padding: var(--sp-5);
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-1);
      color: var(--ink);
      transition: transform var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
    }
    .cat-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-2);
      border-color: var(--border-strong);
      text-decoration: none;
    }
    .cat-icon {
      flex: none;
      width: 56px;
      height: 56px;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .cat-green {
      background: color-mix(in srgb, var(--lens-green) 26%, transparent);
      color: var(--lens-green);
    }
    .cat-blue {
      background: color-mix(in srgb, var(--lens-blue) 26%, transparent);
      color: var(--lens-blue);
    }
    .cat-purple {
      background: color-mix(in srgb, var(--lens-purple) 26%, transparent);
      color: var(--lens-purple);
    }
    .cat-body {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .cat-title {
      font-weight: 680;
      font-size: 1.02rem;
      color: var(--ink);
    }
    .cat-text {
      font-size: 0.92rem;
      line-height: 1.4;
      color: var(--muted);
    }

    /* ---------- Lens grid ---------- */
    .lens-section {
      margin-top: 24px;
    }
    .lens-section h2 {
      font-size: 1.25rem;
      font-weight: 680;
      letter-spacing: -0.01em;
      margin: 0 0 12px;
    }
    .lens-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .lens-tile {
      position: relative;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: start;
      padding: 14px 16px;
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-1);
      color: var(--ink);
      transition: transform var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
    }
    .lens-tile:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-2);
      border-color: var(--border-strong);
      text-decoration: none;
    }
    .lens-tile:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      border-radius: var(--radius);
    }
    .tile-icon {
      position: relative;
      width: 48px;
      height: 48px;
      align-self: center;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      box-shadow: var(--shadow-1);
    }
    .tile-icon::after {
      content: '';
      position: absolute;
      left: 37px;
      top: 36px;
      margin-top: -3px;
      width: 16px;
      height: 6px;
      border-radius: 999px;
      background: var(--tile-c);
      transform-origin: 0 50%;
      transform: rotate(42deg);
    }
    .tile-text {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
      padding-top: 22px;
    }
    .tile-name {
      font-weight: 680;
      font-size: 0.98rem;
      line-height: 1.25;
      color: var(--ink);
    }
    .tile-tag {
      font-size: 13px;
      line-height: 1.35;
      color: var(--muted);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .pill {
      position: absolute;
      top: 10px;
      right: 10px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.02em;
      line-height: 1.2;
      white-space: nowrap;
    }
    .pill--installed {
      background: var(--status-installed);
      color: var(--status-installed-ink);
    }
    .pill--available {
      background: var(--status-available);
      color: var(--status-available-ink);
    }
    .pill--coming-soon {
      background: var(--status-comingsoon);
      color: var(--status-comingsoon-ink);
    }

    /* ---------- Responsive ---------- */
    @media (max-width: 940px) {
      .lens-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 820px) {
      .hero {
        grid-template-columns: 1fr;
        gap: var(--sp-5);
      }
      .hero-text { order: 1; }
      .hero-art-wrap { order: 2; }
      .hero-sub { max-width: none; }
      .hero-art { max-width: 380px; }
      .cat-cards { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .lens-grid { grid-template-columns: 1fr; }
      .hero-text h1 { font-size: clamp(2rem, 9vw, 2.6rem); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-art,
      .hero-mark,
      .hero-text {
        animation: none;
      }
    }
  </style>
</BaseLayout>