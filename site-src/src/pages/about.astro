---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocsSearch from '../components/DocsSearch.astro';
---

<BaseLayout title="FAQ & Support · CopilotScope">
  <section class="support">
    <h1 class="support-title">FAQ &amp; Support</h1>

    <div class="support-search">
      <DocsSearch />
    </div>

    <section class="support-access">
      <h2>Access &amp; support</h2>
      <p>If your organization's network blocks copilotscope.ai, use aka.ms/CopilotScope as an alternate address.</p>
    </section>
  </section>
</BaseLayout>

<style>
  .support {
    max-width: 720px;
  }
  .support-title {
    font-size: 2rem;
    font-weight: 650;
    line-height: 1.2;
    margin: 0 0 var(--sp-5);
  }
  .support-search {
    max-width: 640px;
    margin-bottom: var(--sp-6);
  }
  .support-access {
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
  }
  .support-access h2 {
    font-size: 1.1rem;
    font-weight: 650;
    margin: 0 0 var(--sp-2);
    color: var(--ink);
  }
  .support-access p {
    font-size: 1rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
    max-width: 62ch;
  }
</style>
