  // --- Theme toggle glyphs ---
  sun: {
    body: `<circle cx="10" cy="10" r="3.4" />
<path d="M10 2.2 V4.2 M10 15.8 V17.8 M2.2 10 H4.2 M15.8 10 H17.8 M4.5 4.5 L5.9 5.9 M14.1 14.1 L15.5 15.5 M15.5 4.5 L14.1 5.9 M5.9 14.1 L4.5 15.5" />`,
  },
  moon: {
    body: `<path d="M15.6 11.6 A6 6 0 1 1 8.4 4.4 A4.7 4.7 0 0 0 15.6 11.6 Z" />`,
  },
};

const glyph = ICONS[name];
if (!glyph) {
  throw new Error(`Icon: unknown name "${name}"`);
}
const view = glyph.view ?? '0 0 20 20';
const sw = glyph.sw ?? 1.75;
---

<svg
  class:list={['icon', className]}
  width={size}
  height={size}
  viewBox={view}
  fill="none"
  stroke="currentColor"
  stroke-width={sw}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  set:html={glyph.body}
/>
