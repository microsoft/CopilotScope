---
/*
  Icon.astro — hand-authored Fluent-style outline glyphs.

  Every glyph is an inline SVG (no runtime dependency, no external CDN — satisfies
  the static / no-network site constraint). Default authoring grid is a 20x20
  viewBox with a 1.75 stroke, round caps + joins, fill:none stroke:currentColor —
  so a glyph inherits its color from the surrounding CSS `color` (that is how the
  selected rail row tints icon + label accent-blue and how each lens row tints its
  motif in its brand color).

  All glyphs are original hand-authored Fluent-style outlines EXCEPT `github`,
  which follows the conventional GitHub repo-link mark (Feather-style outline,
  24x24 grid) used purely to link out to the source repository.
*/
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 20, class: className } = Astro.props;

type Glyph = { view?: string; sw?: number; body: string };

const ICONS: Record<string, Glyph> = {
