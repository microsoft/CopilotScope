---
import { getEntry } from 'astro:content';

interface Props {
  id: string;
}
const { id } = Astro.props;

const entry = await getEntry('lenses', id);
if (!entry) {
  throw new Error(`LensStub: no lens entry found for id "${id}"`);
}
const { name, tagline, status, color, category } = entry.data;
const comingSoon = status === 'coming-soon';
---

<section class="lens-stub">
  <div class="lens-head">
    <span class="lens-dot" style={`background: var(--${color})`} aria-hidden="true"></span>
    <h1>{name}</h1>
    {
      status === 'installed' ? (
        <span class="pill pill-installed">Installed</span>
      ) : comingSoon ? (
        <span class="pill pill-soon">Coming Soon</span>
      ) : (
        <span class="pill pill-live">Available</span>
      )
    }
  </div>
  <p class="category">{category}</p>
  <p class="tagline">{tagline}</p>
  <p class="lede">In build — full content coming soon.</p>
</section>

<style>
  .lens-stub {
    max-width: 64ch;
  }
  .lens-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
    margin-bottom: var(--sp-2);
  }
  .lens-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .lens-head h1 {
    font-size: 2rem;
    font-weight: 650;
    margin: 0;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.05;
    white-space: nowrap;
    border-radius: 999px;
  }
  .pill-soon {
    background: var(--status-comingsoon);
    color: var(--status-comingsoon-ink);
  }
  .pill-installed {
    background: var(--status-installed);
    color: var(--status-installed-ink);
  }
  .pill-live {
    background: var(--status-available);
    color: var(--status-available-ink);
  }
  .category {
    margin: 0 0 var(--sp-3);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--subtle);
  }
  .tagline {
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0 0 var(--sp-4);
  }
  .lede {
    font-size: 1rem;
    color: var(--muted);
    margin: 0;
  }
</style>
