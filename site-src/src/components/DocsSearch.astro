---
// Reusable documentation search surface. In this phase every docs page passes
// its lens slug, so search is lens-scoped; Phase 3.3b.4 will reuse the same
// component with no lens filter for global search. The whole surface is
// excluded from the Pagefind index.
interface Props {
  lens?: string;
  lensName?: string;
}
const { lens = '', lensName = '' } = Astro.props;
const label = lensName ? `Search ${lensName} documentation` : 'Search documentation';
---

<section
  class="docs-search"
  data-docs-search
  data-lens={lens}
  data-pagefind-ignore="all"
  aria-label={label}
>
  <label class="ds-label" for="ds-input">{label}</label>
  <div class="ds-field">
    <span class="ds-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7" />
        <path d="m21 21-4.3-4.3" />
      </svg>
    </span>
    <input
      id="ds-input"
      class="ds-input"
      type="search"
      data-ds-input
      placeholder={label}
      autocomplete="off"
      spellcheck="false"
      enterkeyhint="search"
    />
  </div>
  <p class="ds-status" data-ds-status role="status" aria-live="polite"></p>
  <ul class="ds-results" data-ds-results></ul>
</section>

<script>
  import '../scripts/docs-search-client';
</script>

<style>
  .docs-search {
    display: grid;
    gap: var(--sp-2);
  }
  .ds-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
  }
  .ds-field {
    position: relative;
    display: flex;
    align-items: center;
  }
  .ds-icon {
    position: absolute;
    left: var(--sp-3);
    display: inline-flex;
    color: var(--muted);
    pointer-events: none;
  }
  .ds-icon svg {
    width: 16px;
    height: 16px;
  }
  .ds-input {
    width: 100%;
    padding: var(--sp-2) var(--sp-3) var(--sp-2) calc(var(--sp-3) + 22px);
    font: inherit;
    font-size: 0.95rem;
    color: var(--ink);
    background: var(--surface-card);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
  }
  .ds-input::placeholder {
    color: var(--muted);
  }
  .ds-input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-color: var(--accent);
  }
  .ds-status {
    margin: 0;
    min-height: 1.2em;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .ds-results {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--sp-2);
  }
  .ds-result {
    padding: var(--sp-2) 0;
    border-top: 1px solid var(--border);
  }
  .ds-result:first-child {
    border-top: none;
  }
  .ds-result-link {
    display: block;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .ds-result-link:hover .ds-result-title {
    text-decoration: underline;
  }
  .ds-result-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .ds-result-excerpt {
    margin: 2px 0 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--muted);
  }
  .ds-result-excerpt :global(mark) {
    background: color-mix(in srgb, var(--accent) 24%, transparent);
    color: var(--ink);
    padding: 0 2px;
    border-radius: 2px;
  }
</style>
